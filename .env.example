# NextGen API & storage (copy to .env and adjust as needed)
PORT=3000
MONGODB_URI=mongodb://localhost:27017/nextgen
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=nextgen-materials

# Auth0 (Regular Web Application — server-side OAuth callback)
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret
# Optional; defaults to http://localhost:3000/api/auth/oauth/callback when omitted
AUTH0_CALLBACK_URL=http://localhost:3000/api/auth/oauth/callback
AUTH0_GOOGLE_CONNECTION=google-oauth2

# Auth & sessions
SESSION_SECRET=change-me-in-production
ALLOWED_EMAIL_DOMAIN=ninjavan.co
EMAIL_ALLOWLIST=diniseprilia@gmail.com
BOOTSTRAP_ADMIN_EMAIL=diniseprilia@gmail.com

# Google Gemini (optional — can also be set in Admin Settings UI)
GEMINI_API_KEY=
